{
  "name": "@eregion/node-agent",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@eregion/config": "workspace:*",
    "@eregion/protocol": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@opentelemetry/context-async-hooks": "^1.28.0",
    "@opentelemetry/core": "^1.28.0",
    "@opentelemetry/instrumentation": "^0.55.0",
    "@opentelemetry/instrumentation-http": "^0.55.0",
    "@opentelemetry/instrumentation-express": "^0.44.0",
    "@opentelemetry/instrumentation-pg": "^0.49.0",
    "@opentelemetry/instrumentation-mysql2": "^0.44.0",
    "@opentelemetry/instrumentation-mongodb": "^0.50.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudyWSA/eregion.git"
  }
}
