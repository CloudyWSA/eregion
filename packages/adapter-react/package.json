{
  "name": "@eregion/adapter-react",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@eregion/overlay": "workspace:*",
    "@eregion/protocol": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^25.0.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudyWSA/eregion.git"
  }
}
