{
  "name": "@eregion/daemon",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eregion-dev": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.206",
    "@eregion/config": "workspace:*",
    "@eregion/protocol": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "ts-morph": "^24.0.0",
    "@angular/compiler": "^20.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudyWSA/eregion.git"
  }
}
