{
  "name": "@eregion/overlay",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Eregion in-app overlay: click to select a component, describe a change, and watch AI edit the real source live.",
  "keywords": [
    "eregion",
    "ai",
    "devtools",
    "overlay",
    "visual-editing",
    "live-editing",
    "component-selector",
    "frontend"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "default": "./dist/auto.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/auto.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@eregion/protocol": "workspace:*",
    "preact": "^10.24.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudyWSA/eregion.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/auto.js"
  ]
}
